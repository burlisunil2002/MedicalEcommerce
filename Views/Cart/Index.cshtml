@model VivekMedicalProducts.ViewModels.CartItemViewModel

<div class="max-w-7xl mx-auto px-4 py-8">

    <h2 class="text-3xl font-bold text-center mb-8">
        🛒 Your Cart
    </h2>

    @if (!Model.CartItems.Any())
    {
        <div class="text-center py-20 text-gray-500">
            Your cart is empty
        </div>
    }
    else
    {
        <div class="grid lg:grid-cols-3 gap-8">

            <!-- 🧾 CART ITEMS -->
            <div class="lg:col-span-2 space-y-5">

                @foreach (var item in Model.CartItems)
                {
                    decimal original = item.Product.Price;

                    decimal final = item.Product.IsHotDeal && item.Product.DiscountPercentage > 0
                    ? original - (original * item.Product.DiscountPercentage.Value / 100)
                    : original;

                    decimal saved = (original - final) * item.Quantity;

                    <div class="cart-area bg-white p-5 rounded-xl shadow hover:shadow-xl transition flex justify-between items-center"
                         data-id="@item.ProductId">

                        <!-- LEFT -->
                        <div class="flex items-center gap-4">

                            <img src="@item.Product.ImageUrl"
                                 class="w-20 h-20 object-contain rounded" />

                            <div>
                                <h3 class="font-semibold text-gray-800">
                                    @item.Product.Name
                                </h3>

                                <div class="flex items-center gap-2">

                                    <span class="text-green-600 font-bold">
                                        ₹ @final
                                    </span>

                                    @if (original > final)
                                    {
                                        <span class="line-through text-gray-400 text-sm">
                                            ₹ @original
                                        </span>
                                    }
                                </div>

                                @if (saved > 0)
                                {
                                    <p class="text-xs text-green-500">
                                        You saved ₹ @saved
                                    </p>
                                }
                            </div>
                        </div>

                        <!-- RIGHT -->
                        <div class="flex items-center gap-4">

                            <div class="qty-controller flex items-center bg-gray-100 rounded-lg px-2 py-1">

                                <button class="minus px-2 text-lg">-</button>

                                <span class="qty px-3 font-semibold">
                                    @item.Quantity
                                </span>

                                <button class="plus px-2 text-lg">+</button>
                            </div>

                            <button class="delete-btn text-red-500 text-xl hover:scale-110 transition">
                                🗑️
                            </button>

                        </div>
                    </div>
                }

            </div>

            <!-- 📊 SUMMARY -->
            <div class="bg-white p-6 rounded-2xl shadow sticky top-20 space-y-4">

                <h3 class="text-lg font-semibold border-b pb-2">
                    Order Summary
                </h3>

                <!-- COUPON -->
                <select id="couponSelect"
                        class="w-full border rounded px-3 py-2">
                    <option value="">Select Offer</option>
                    <option value="SAVE10">Save 10%</option>
                    <option value="SAVE20">Save 20%</option>
                    <option value="FLAT100">Flat ₹100</option>
                </select>

                <button id="applyCoupon"
                        class="w-full bg-gradient-to-r from-blue-500 to-indigo-600 text-white py-2 rounded-lg hover:scale-105 transition shadow">
                    Apply Offer
                </button>

                <p id="couponMsg" class="text-sm font-medium"></p>

                <!-- TOTALS -->
                <div class="space-y-3 text-sm">

                    <div class="flex justify-between">
                        <span>Subtotal</span>
                        <span id="subtotal">₹ @Model.SubTotal</span>
                    </div>

                    <div class="flex justify-between">
                        <span>GST</span>
                        <span id="gsttotal">₹ @Model.GSTTotal</span>
                    </div>

                    <div class="flex justify-between text-green-600">
                        <span>You Saved</span>
                        <span id="saved">₹ @Model.Discount</span>
                    </div>

                    <div class="flex justify-between">
                        <span>Delivery</span>
                        <span id="delivery">
                            @(Model.Delivery == 0 ? "FREE" : "₹ 5")
                        </span>
                    </div>

                    <!-- 🚚 DELIVERY PROGRESS -->
                    <div>
                        <p id="deliveryMsg" class="text-xs text-orange-500"></p>

                        <div class="w-full bg-gray-200 rounded-full h-2 mt-1">
                            <div id="deliveryBar"
                                 class="bg-gradient-to-r from-green-400 to-green-600 h-2 rounded-full transition-all duration-500"
                                 style="width:0%">
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-between text-red-500">
                        <span>Coupon</span>
                        <span id="couponAmount">₹ 0</span>
                    </div>

                    <hr>

                    <div class="flex justify-between text-lg font-bold text-green-600">
                        <span>Total</span>
                        <span id="grandtotal">₹ @Model.GrandTotal</span>
                    </div>

                </div>

                <!-- BUTTONS -->
                <a asp-controller="Checkout"
                   asp-action="Index"
                   class="block w-full bg-green-600 hover:bg-green-700 text-white py-3 rounded-xl text-center font-semibold transition">
                    Proceed to Checkout →
                </a>

                <a asp-controller="Products"
                   asp-action="Index"
                   class="block w-full bg-orange-500 hover:bg-orange-600 text-white py-2 rounded text-center transition">
                    ← Continue Shopping
                </a>

            </div>

        </div>
    }
</div>