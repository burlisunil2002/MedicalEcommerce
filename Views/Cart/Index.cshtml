@model VivekMedicalProducts.ViewModels.CartItemViewModel

<div class="max-w-7xl mx-auto px-6 py-10">

    <h2 class="text-3xl font-semibold text-gray-800 mb-8 text-center">
        Your Shopping Cart
    </h2>

    @if (!Model.CartItems.Any())
    {
        <div id="emptyCart"
             class="bg-blue-50 border border-blue-200 text-blue-700 p-5 rounded-lg text-center">
            Your cart is empty
        </div>
    }
    else
    {

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <!-- CART ITEMS -->

            <div id="cartItems" class="lg:col-span-2 space-y-5">

                @foreach (var item in Model.CartItems)
                {
                    decimal netAmount = item.Product.Price * item.Quantity;
                    decimal gstAmount = netAmount * ((decimal)item.Product.GSTPercentage / 100);
                    decimal totalAmount = netAmount + gstAmount;

                    <div class="cart-item bg-white shadow-md rounded-xl p-5 flex justify-between items-center"
                         data-cartid="@item.Id">

                        <!-- PRODUCT -->

                        <div class="flex gap-4 items-center">

                            <img src="@item.Product.ImagePath"
                                 class="w-20 h-20 rounded-lg object-cover" />

                            <div>

                                <h3 class="font-semibold text-gray-800">
                                    @item.Product.Name
                                </h3>

                                <p class="text-sm text-gray-500">
                                    GST : @item.Product.GSTPercentage %
                                </p>

                                <p class="text-green-600 font-semibold">
                                    ₹ @item.Product.Price
                                </p>

                            </div>

                        </div>

                        <!-- QUANTITY -->

                        <div class="flex items-center gap-2">

                            <button class="qty-btn bg-gray-200 hover:bg-gray-300 px-3 py-1 rounded"
                                    data-cartid="@item.Id"
                                    data-price="@item.Product.Price"
                                    data-gst="@item.Product.GSTPercentage"
                                    data-change="-1">
                                -
                            </button>

                            <input type="number"
                                   value="@item.Quantity"
                                   class="qty-input w-14 text-center border rounded"
                                   data-cartid="@item.Id"
                                   data-price="@item.Product.Price"
                                   data-gst="@item.Product.GSTPercentage" />

                            <button class="qty-btn bg-gray-200 hover:bg-gray-300 px-3 py-1 rounded"
                                    data-cartid="@item.Id"
                                    data-price="@item.Product.Price"
                                    data-gst="@item.Product.GSTPercentage"
                                    data-change="1">
                                +
                            </button>

                        </div>
                       

                        <!-- REMOVE -->

                        <button class="remove-btn text-red-500 text-xl hover:text-red-700"
                                data-cartid="@item.Id">
                            ✕
                        </button>

                    </div>
                }

            </div>

            <!-- ORDER SUMMARY -->

            <div class="bg-white shadow-lg rounded-xl p-6 h-fit sticky top-24">

                <h3 class="text-lg font-semibold mb-4">
                    Order Summary
                </h3>

                <div class="flex justify-between mb-2 text-gray-600">
                    <span>Subtotal</span>
                    <span id="subtotal">₹ @Model.SubTotal.ToString("0.00")</span>
                </div>

                <div class="flex justify-between mb-3 text-gray-600">
                    <span>GST</span>
                    <span id="gsttotal">₹ @Model.GSTTotal.ToString("0.00")</span>
                </div>

                <hr class="my-3">

                <div class="flex justify-between text-lg font-semibold text-green-600">
                    <span>Total</span>
                    <span id="grandtotal">₹ @Model.GrandTotal.ToString("0.00")</span>
                </div>

                <a asp-controller="Checkout"
                   asp-action="Index"
                   class="block mt-5 bg-green-500 hover:bg-green-600 text-white text-center py-2 rounded-lg">
                    Proceed to Checkout
                </a>

            </div>

        </div>

    }

</div>

<script>

    function updateCart(cartId, qty){

    fetch('/Cart/UpdateQuantity', {

    method:'POST',

    headers:{
    'Content-Type':'application/x-www-form-urlencoded'
    },

    body:`cartId=${cartId}&quantity=${qty}`

    })
    .then(res=>res.json())
    .then(data=>{

    if(data.success){

    updateTotals();

    }

    });

    }

    // QUANTITY BUTTON

    document.querySelectorAll(".qty-btn").forEach(btn=>{

    btn.addEventListener("click",function(){

    let cartId=this.dataset.cartid;
    let price=parseFloat(this.dataset.price);
    let gst=parseFloat(this.dataset.gst);
    let change=parseInt(this.dataset.change);

    let input=document.querySelector(`.qty-input[data-cartid='${cartId}']`);

    let qty=parseInt(input.value)+change;

    if(qty<1) return;

    input.value=qty;

    let net=price*qty;
    let gstAmount=net*(gst/100);
    let total=net+gstAmount;

    document.querySelector(`.item-total[data-cartid='${cartId}']`)
    .innerText="₹ "+total.toFixed(2);

    updateCart(cartId,qty);

    updateTotals();

    });

    });

    // REMOVE ITEM

    document.querySelectorAll(".remove-btn").forEach(btn=>{

    btn.addEventListener("click",function(){

    let cartId=this.dataset.cartid;

    fetch('/Cart/Remove',{

    method:'POST',

    headers:{
    'Content-Type':'application/x-www-form-urlencoded'
    },

    body:`id=${cartId}`

    })
    .then(res=>res.json())
    .then(data=>{

    if(data.success){

    let item=document.querySelector(`.cart-item[data-cartid='${cartId}']`);

    item.remove();

    updateTotals();

    if(document.querySelectorAll(".cart-item").length===0){

    document.getElementById("cartItems").innerHTML=
    '<div class="bg-blue-50 border border-blue-200 text-blue-700 p-5 rounded-lg text-center">Your cart is empty</div>';

    }

    }

    });

    });

    });

    // UPDATE TOTALS

    function updateTotals(){

    let subtotal=0;
    let gsttotal=0;

    document.querySelectorAll(".qty-input").forEach(input=>{

    let qty=parseInt(input.value);
    let price=parseFloat(input.dataset.price);
    let gst=parseFloat(input.dataset.gst);

    let net=qty*price;
    let gstAmount=net*(gst/100);

    subtotal+=net;
    gsttotal+=gstAmount;

    });

    let grand=subtotal+gsttotal;

    document.getElementById("subtotal").innerText="₹ "+subtotal.toFixed(2);
    document.getElementById("gsttotal").innerText="₹ "+gsttotal.toFixed(2);
    document.getElementById("grandtotal").innerText="₹ "+grand.toFixed(2);

    }

</script>