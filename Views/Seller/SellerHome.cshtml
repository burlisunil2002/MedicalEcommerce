<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Become a Seller | MedMarket</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-50 font-sans">

    <!-- 🔹 HERO -->
    <section class="bg-gradient-to-br from-blue-600 to-indigo-600 text-white py-20">
        <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 items-center px-6">

            <div>
                <h2 class="text-4xl font-bold leading-tight">
                    Sell Medical Products Across India 🚀
                </h2>

                <p class="mt-4 text-lg text-blue-100">
                    Reach hospitals, clinics, and distributors.
                    Grow your business with our trusted marketplace.
                </p>

                <!-- CTA -->
                <div class="mt-8 flex gap-4">
                    <a href="/Seller/Register"
                       class="bg-white text-blue-600 px-6 py-3 rounded-xl font-semibold hover:bg-gray-100">
                        Start Selling
                    </a>

                    <a href="/Seller/Login"
                       class="border border-white px-6 py-3 rounded-xl hover:bg-white hover:text-blue-600">
                        Sign In
                    </a>
                </div>

                <!-- TRUST -->
                <div class="mt-8 flex gap-6 text-sm text-blue-200">
                    <span>✔ Trusted Platform</span>
                    <span>✔ Secure Payments</span>
                    <span>✔ Fast Delivery</span>
                </div>
            </div>

            <div>
                <img src="/images/sellerimage.jpg"
                     alt="Medical Logistics"
                     class="rounded-2xl shadow-xl object-cover w-full h-[420px]" />
            </div>

        </div>
    </section>

    <!-- 🔹 STATS -->
    <section class="bg-white py-12">
        <div class="max-w-6xl mx-auto grid md:grid-cols-3 text-center gap-8">

            <div>
                <h3 class="text-3xl font-bold text-blue-600">10K+</h3>
                <p class="text-gray-600">Products Sold</p>
            </div>

            <div>
                <h3 class="text-3xl font-bold text-blue-600">5K+</h3>
                <p class="text-gray-600">Verified Buyers</p>
            </div>

            <div>
                <h3 class="text-3xl font-bold text-blue-600">100+</h3>
                <p class="text-gray-600">Active Sellers</p>
            </div>

        </div>
    </section>

    <!-- 🔹 WHY SELL -->
    <section class="py-16 max-w-6xl mx-auto px-6">
        <h3 class="text-3xl font-bold text-center mb-10">
            Why Choose MedMarket?
        </h3>

        <div class="grid md:grid-cols-3 gap-8">

            <div class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">
                <h4 class="text-xl font-semibold mb-2 text-blue-600">📦 Easy Listing</h4>
                <p class="text-gray-600">Upload and manage products easily.</p>
            </div>

            <div class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">
                <h4 class="text-xl font-semibold mb-2 text-blue-600">💰 Fast Payments</h4>
                <p class="text-gray-600">Get paid quickly and securely.</p>
            </div>

            <div class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">
                <h4 class="text-xl font-semibold mb-2 text-blue-600">🚚 Logistics</h4>
                <p class="text-gray-600">Integrated delivery support.</p>
            </div>

        </div>
    </section>

    <!-- 🔹 CATEGORIES -->
    <section class="bg-gray-100 py-16 px-6">
        <div class="max-w-6xl mx-auto text-center">

            <h3 class="text-3xl font-bold mb-10">
                What You Can Sell
            </h3>

            <div class="grid md:grid-cols-4 gap-6">

                <div class="bg-white p-4 rounded-xl shadow">
                    Consumables
                </div>

                <div class="bg-white p-4 rounded-xl shadow">
                    Diagnostic Tools
                </div>

                <div class="bg-white p-4 rounded-xl shadow">
                    Surgical Equipment
                </div>

                <div class="bg-white p-4 rounded-xl shadow">
                    Hospital Equipment
                </div>

            </div>
        </div>
    </section>

    <!-- 🔹 FINAL CTA -->
    <section class="py-16 text-center bg-blue-600 text-white">
        <h3 class="text-3xl font-bold mb-4">
            Start Selling Today 🚀
        </h3>

        <p class="mb-6 text-blue-100">
            Register your business and grow faster.
        </p>

        <a href="/Seller/Register"
           class="bg-white text-blue-600 px-8 py-3 rounded-xl font-semibold hover:bg-gray-100">
            Register Now
        </a>
    </section>

</body>
</html>