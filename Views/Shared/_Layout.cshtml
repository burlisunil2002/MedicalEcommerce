        /*-------------Scroll Head Bar ------------*/

        .announcement-bar {
            width: 100%;
            background: linear-gradient(90deg, #0f2027, #203a43, #2c5364);
            color: #fff;
            overflow: hidden;
            position: relative;
            height: 40px;
            display: flex;
            align-items: center;
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 0.5px;
            z-index: 999;
        }

        .announcement-track {
            display: inline-block;
            white-space: nowrap;
            animation: scrollText 15s linear infinite;
        }

            .announcement-track span {
                padding-left: 100%;
            }

        @@keyframes scrollText {
            0%

        {
            transform: translateX(0%);
        }

        100% {
            transform: translateX(-100%);
        }

        }

        /* Responsive */
        @@media (max-width: 768px) {
            .announcement-bar

        {
            font-size: 12px;
            height: 35px;
        }

        }

    </style>

