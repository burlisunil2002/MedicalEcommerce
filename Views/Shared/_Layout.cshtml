<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sunil Medical</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <link href="~/css/output.css" rel="stylesheet" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- SweetAlert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <partial name="_ValidationScriptsPartial" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .menu-item {
            display: block;
            padding: 10px;
            border-radius: 8px;
            transition: 0.2s;
        }

            .menu-item:hover {
                background: #f3f4f6;
            }
    </style>

    @RenderSection("Styles", required: false)

</head>

<!-- WHATSAPP FLOAT BUTTON -->
<a href="https://wa.me/919014060858?text=Hi%20I%20need%20support"
   target="_blank"
   class="fixed bottom-5 right-5 z-50 flex items-center justify-center w-14 h-14 rounded-full bg-green-500 shadow-lg hover:bg-green-600 hover:scale-110 transition-all duration-300">

    <!-- WhatsApp Icon -->
    <svg xmlns="http://www.w3.org/2000/svg"
         viewBox="0 0 32 32"
         class="w-7 h-7 fill-white">
        <path d="M16 .5A15.5 15.5 0 0 0 2.5 23.1L.5 31.5l8.6-2A15.5 15.5 0 1 0 16 .5zm0 28.5c-2.4 0-4.7-.7-6.6-2l-.5-.3-5.1 1.2 1.3-5-.3-.5a12.6 12.6 0 1 1 11.2 6.6zm6.9-9.3c-.4-.2-2.4-1.2-2.8-1.3-.4-.2-.7-.2-1 .2s-1.1 1.3-1.3 1.5c-.2.2-.5.3-.9.1-.4-.2-1.7-.6-3.3-2-.1-.1-1.6-1.4-2.2-2.9-.2-.4 0-.7.2-.9.2-.2.4-.5.6-.7.2-.2.3-.4.4-.6.1-.2.1-.5 0-.7-.1-.2-1-2.4-1.4-3.3-.3-.8-.7-.7-1-.7h-.9c-.3 0-.7.1-1 .5s-1.4 1.3-1.4 3.1 1.4 3.6 1.6 3.9c.2.3 2.8 4.3 6.8 6 .9.4 1.6.6 2.1.8.9.3 1.7.3 2.3.2.7-.1 2.4-1 2.7-2 .3-1 .3-1.9.2-2.1-.1-.2-.3-.3-.7-.5z" />
    </svg>

</a>

<body class="bg-gray-50">

    <!-- 🔥 HEADER -->
    <header class="bg-white shadow-md sticky top-0 z-50">

        <div class="max-w-7xl mx-auto px-4">

            <div class="flex items-center justify-between h-16">

                <!-- LOGO -->
                <div class="flex items-center gap-2">
                    <img src="~/images/amtz png.png" class="h-10">
                </div>

                <!-- SEARCH -->
                <form class="hidden md:flex flex-1 mx-6 relative"
                      asp-controller="Products"
                      asp-action="Index"
                      method="get">

                    <input type="text"
                           name="searchString"
                           placeholder="Search medical products..."
                           class="w-full px-5 py-2 rounded-full border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none shadow-sm">

                    <button type="submit"
                            class="absolute right-1 top-1 bg-blue-600 text-white px-4 py-1 rounded-full hover:bg-blue-700">
                        <i class="fa fa-search"></i>
                    </button>

                </form>

                <!-- RIGHT MENU -->
                <div class="flex items-center gap-5">

                    <a asp-controller="Products" asp-action="Index"
                       class="hidden md:block hover:text-blue-600 font-medium">
                        Explore
                    </a>

                    <!-- CART -->
                    <a asp-controller="Cart"
                       asp-action="Index"
                       class="relative">

                        <i class="fa fa-shopping-cart text-xl"></i>

                        <span id="cartCount"
                              class="absolute -top-2 -right-3 bg-red-500 text-white text-xs px-1.5 rounded-full">
                            0
                        </span>

                    </a>

                    <!-- USER -->
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="relative">

                            <button id="userMenuBtn"
                                    class="flex items-center gap-2 bg-gray-100 px-3 py-2 rounded-full hover:bg-gray-200">

                                <i class="fa fa-user"></i>

                                <span class="text-sm font-medium">
                                    @User.Identity.Name
                                </span>

                                <i class="fa fa-chevron-down text-xs"></i>
                            </button>

                            <!-- DROPDOWN -->
                            <div id="userDropdown"
                                 class="hidden absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-lg border p-2 z-50">

                                <a asp-controller="Account" asp-action="Register"
                                   class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-100">
                                    👤 Customer Registration
                                </a>

                                <a asp-controller="Account" asp-action="Profile"
                                   class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-100">
                                    👤 My Profile
                                </a>

                                <a asp-controller="Order" asp-action="MyOrders"
                                   class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-100">
                                    📦 My Orders
                                </a>

                                <!-- SUPPORT -->
                                <a asp-controller="Home" asp-action="Enquiry"
                                   class="flex items-center gap-2 p-2 rounded-lg hover:bg-blue-50 text-blue-600 font-medium">
                                    🎧 Customer Support
                                </a>


                                <hr class="my-2">

                                <a asp-controller="Account" asp-action="Logout"
                                   class="menu-item text-red-500">
                                    🚪 Logout
                                </a>

                            </div>

                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account"
                           asp-action="Login"
                           class="bg-blue-600 text-white px-4 py-2 rounded-full hover:bg-blue-700">
                            Login
                        </a>
                    }

                </div>

            </div>

        </div>

    </header>

    <!-- 🔥 PAGE CONTENT -->
    <main class="max-w-7xl mx-auto px-4 py-6 min-h-screen">
        @RenderBody()
    </main>

    <!-- 🔥 FOOTER -->
    <footer class="bg-white border-t mt-10">
        <div class="max-w-7xl mx-auto px-4 py-6 text-center text-gray-600">

            <h5 class="font-semibold text-lg">Sunil Medical Products</h5>

            <p class="text-sm mt-1">
                Advanced Medical Equipment & Trusted Healthcare Solutions
            </p>

            <p class="text-xs mt-2 text-gray-400">
                © @DateTime.UtcNow.Year Sunil Medical. All Rights Reserved
            </p>

        </div>
    </footer>

    <!-- 🔥 SCRIPTS -->

    <script>
        $(document).ready(function () {

            loadCartCount();

            $("#userMenuBtn").click(function (e) {
                e.stopPropagation();
                $("#userDropdown").toggleClass("hidden");
            });

            $("#moreMenuBtn").click(function (e) {
                e.stopPropagation();
                $("#moreDropdown").toggleClass("hidden");
            });

            $(document).click(function () {
                $("#userDropdown").addClass("hidden");
                $("#moreDropdown").addClass("hidden");
            });

        });

        function loadCartCount() {
            $.get("/Cart/GetCartCount", function (data) {
                $("#cartCount").text(data);
            });
        }

           
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>