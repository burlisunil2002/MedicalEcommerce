    <!-- 🔥 SCRIPTS -->

    <script>
        console.log("BASE:", window.location.origin);
    </script>

    <script>    

        $(document).ready(function () {


            $("#userMenuBtn").click(function (e) {
                e.stopPropagation();
                $("#userDropdown").toggleClass("hidden");
            });

            $("#moreMenuBtn").click(function (e) {
                e.stopPropagation();
                $("#moreDropdown").toggleClass("hidden");
            });

            $(document).click(function () {
                $("#userDropdown").addClass("hidden");
                $("#moreDropdown").addClass("hidden");
            });

        });

              
        // ✅ Prevent popup after skip (session only)
        document.addEventListener("DOMContentLoaded", function () {

            const popup = document.getElementById("profilePopup");

            if (!popup) return;

            // If already skipped → hide
            if (sessionStorage.getItem("profilePopupClosed") === "true") {
                popup.remove();
            }
        });

        function closeProfilePopup() {
            sessionStorage.setItem("profilePopupClosed", "true");
            document.getElementById("profilePopup")?.remove();
        }

    </script>

    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "Organization",
          "name": "Sunil Medical Products",
          "url": "https://sunilmedicalproducts.online",
          "logo": "https://sunilmedicalproducts.online/images/sunillogo.png"
        }
    </script>

    <script>
        const searchBox = document.getElementById("searchBox");
        const suggestions = document.getElementById("suggestions");

        let debounceTimer;

        searchBox.addEventListener("keyup", function () {

            clearTimeout(debounceTimer);

            const query = this.value;

            if (query.length < 2) {
                suggestions.classList.add("hidden");
                return;
            }

            debounceTimer = setTimeout(async () => {

                const res = await fetch(`/Products/GetSuggestions?term=${query}`);
                const data = await res.json();

                suggestions.innerHTML = "";

                if (data.length === 0) {
                    suggestions.innerHTML = `<div class="p-2 text-gray-500">No results found</div>`;
                } else {

                    data.forEach(item => {

                        const div = document.createElement("div");
                        div.className = "p-2 hover:bg-gray-100 cursor-pointer";

                        div.innerHTML = `
                            <span class="font-medium">${item.name}</span>
                            <span class="text-sm text-gray-400"> (${item.category})</span>
                        `;

                        // 🔥 CLICK HANDLING
                        div.onclick = () => {
                            window.location.href =
                                `/Products/Index?searchString=${item.name}`;
                        };

                        suggestions.appendChild(div);
                    });
                }

                suggestions.classList.remove("hidden");

            }, 300);
        });

        // 🔥 HIDE WHEN CLICK OUTSIDE
        document.addEventListener("click", function (e) {
            if (!searchBox.contains(e.target) && !suggestions.contains(e.target)) {
                suggestions.classList.add("hidden");
            }
        });
    </script>

           

    @await RenderSectionAsync("Scripts", required: false)

    <script src="~/js/cart.js"></script>


