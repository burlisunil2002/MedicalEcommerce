@model VivekMedicalProducts.ViewModels.PaymentViewModel

<div class="max-w-7xl mx-auto px-6 py-10">

    <h1 class="text-3xl font-bold text-center text-gray-800 mb-10">
        Complete Your Payment
    </h1>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

        <!-- LEFT : PAYMENT DETAILS -->

        <div class="bg-white shadow-lg rounded-2xl p-8">

            <h2 class="text-xl font-semibold text-gray-700 mb-6 border-b pb-3">
                UPI Payment
            </h2>

            <div class="flex flex-col items-center">

                <img src="~/images/Payment.jpeg"
                     class="w-56 h-56 object-contain border rounded-xl p-2 shadow" />

                <p class="mt-4 text-gray-600 text-center">
                    Scan this QR code using any UPI app
                </p>

            </div>

            <!-- BANK DETAILS -->

            <div class="mt-8 bg-gray-50 p-5 rounded-xl">

                <h3 class="font-semibold text-gray-700 mb-3">
                    Bank Transfer Details
                </h3>

                <div class="space-y-2 text-sm text-gray-600">

                    <p><span class="font-medium">Account Name:</span> Andhra Pradesh MedTech Zone Ltd</p>

                    <p><span class="font-medium">Account Type:</span> Current Account</p>

                    <p><span class="font-medium">Account No:</span> 036505005004</p>

                    <p><span class="font-medium">Bank Name:</span> ICICI Bank Ltd</p>

                    <p><span class="font-medium">IFSC Code:</span> ICIC0004362</p>

                    <p>
                        <span class="font-medium">Branch Address:</span>
                        AMTZ Campus Branch, Pragathi Maidan Visakhapatnam-530031, Andhra Pradesh
                    </p>

                </div>

            </div>

            <!-- SECURITY NOTE -->

            <div class="mt-6 bg-green-50 border border-green-200 p-4 rounded-lg text-sm text-green-700">

                ✔ Secure payment through UPI / Bank transfer
                ✔ Your order will be confirmed after payment verification

            </div>

        </div>


        <!-- RIGHT : PAYMENT SUBMIT -->

        <div class="bg-white shadow-lg rounded-2xl p-8">

            <h2 class="text-xl font-semibold text-gray-700 mb-6 border-b pb-3">
                Submit Payment Proof
            </h2>

            <form asp-action="SubmitPayment"
                  method="post"
                  enctype="multipart/form-data"
                  class="space-y-5">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="OrderId" />

                <!-- VALIDATION SUMMARY -->

                <div asp-validation-summary="All"
                     class="text-red-500 text-sm"></div>

                <!-- UTR NUMBER -->

                <div>

                    <label asp-for="UTRNumber"
                           class="block text-sm font-medium text-gray-600 mb-1">
                    </label>

                    <input asp-for="UTRNumber"
                           class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-green-400 outline-none" />

                    <span asp-validation-for="UTRNumber"
                          class="text-red-500 text-sm"></span>

                </div>

                <!-- FILE UPLOAD -->

                <div>

                    <label asp-for="PaymentScreenshot"
                           class="block text-sm font-medium text-gray-600 mb-1">
                    </label>

                    <input type="file"
                           asp-for="PaymentScreenshot"
                           class="w-full border rounded-lg px-3 py-2 bg-gray-50" />

                    <span asp-validation-for="PaymentScreenshot"
                          class="text-red-500 text-sm"></span>

                </div>

                <!-- SUBMIT BUTTON -->

                <button type="submit"
                        class="w-full bg-green-500 hover:bg-green-600 text-white font-semibold py-3 rounded-xl transition">

                    Submit Payment

                </button>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}