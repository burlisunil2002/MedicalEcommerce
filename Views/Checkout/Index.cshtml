@model VivekMedicalProducts.ViewModels.CheckoutViewModel

<div class="min-h-screen bg-gray-100 py-10 px-4">

    <div class="max-w-7xl mx-auto">

        <!-- HEADER -->
        <h1 class="text-3xl font-bold text-gray-800 mb-8 text-center">
            🧾 Checkout
        </h1>

        <div class="grid lg:grid-cols-3 gap-8">

            <!-- LEFT: ADDRESS -->
            <div class="lg:col-span-2 bg-white rounded-2xl shadow-md p-8">

                <h2 class="text-xl font-semibold text-gray-700 mb-6 border-b pb-3">
                    Shipping Details
                </h2>

                <form method="post" action="/Order/Review" class="space-y-5">

                    <!-- NAME -->
                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1">
                            Full Name
                        </label>
                        <input asp-for="FullName"
                               class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500 outline-none"
                               placeholder="Enter your name" required />
                    </div>

                    <!-- PHONE -->
                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1">
                            Phone Number
                        </label>
                        <input asp-for="PhoneNumber"
                               class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500 outline-none"
                               placeholder="Enter phone number" required />
                    </div>

                    <!-- ADDRESS -->
                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1">
                            Address
                        </label>
                        <textarea asp-for="Address"
                                  rows="3"
                                  class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500 outline-none"
                                  placeholder="Enter full address" required></textarea>
                    </div>

                    <!-- CITY + PIN -->
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">City</label>
                            <input asp-for="City"
                                   class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500 outline-none"
                                   required />
                        </div>

                        <div>
                            <label class="block text-sm text-gray-600 mb-1">Pincode</label>
                            <input asp-for="Pincode"
                                   class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-green-500 outline-none"
                                   required />
                        </div>
                    </div>

                    <!-- BUTTON -->
                    <button type="submit"
                            class="w-full mt-4 bg-green-600 hover:bg-green-700 text-white font-semibold py-3 rounded-xl transition shadow">
                        Continue to Review →
                    </button>

                </form>
            </div>

            <!-- RIGHT: SUMMARY -->
            <div class="bg-white rounded-2xl shadow-md p-6 h-fit sticky top-24">

                <h2 class="text-lg font-semibold text-gray-700 mb-5 border-b pb-3">
                    Order Summary
                </h2>

                <!-- ITEMS -->
                <div class="space-y-4 max-h-72 overflow-y-auto pr-2">

                    @foreach (var item in Model.CartItems)
                    {
                        <div class="flex justify-between items-center border-b pb-3">

                            <div>
                                <p class="font-medium text-gray-800 text-sm">
                                    @item.Product.Name
                                </p>

                                <p class="text-xs text-gray-500">
                                    Qty: @item.Quantity
                                </p>
                            </div>

                            <p class="text-green-600 font-semibold text-sm">
                                ₹ @(item.Product.Price* item.Quantity)
                            </p>

                        </div>
                    }

                </div>

                <!-- PRICE DETAILS -->
                <div class="mt-6 space-y-3 text-sm">

                    <div class="flex justify-between text-gray-600">
                        <span>Subtotal</span>
                        <span>₹ @Model.SubTotal.ToString("0.00")</span>
                    </div>

                    <div class="flex justify-between text-gray-600">
                        <span>GST</span>
                        <span>₹ @Model.GST.ToString("0.00")</span>
                    </div>

                    <hr>

                    <div class="flex justify-between text-lg font-bold text-green-600">
                        <span>Total</span>
                        <span>₹ @Model.GrandTotal.ToString("0.00")</span>
                    </div>

                </div>

                <!-- SECURITY NOTE -->
                <p class="text-xs text-gray-400 mt-4 text-center">
                    🔒 Secure checkout powered by Razorpay
                </p>

            </div>

        </div>

    </div>

</div>