@model IEnumerable<VivekMedicalProducts.ViewModels.MyOrderViewModel>

<div class="max-w-7xl mx-auto px-4 py-10">

    <!-- HEADER -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-4">

        <h1 class="text-3xl md:text-4xl font-bold flex items-center gap-2">
            📦 My Orders
        </h1>

        <span class="bg-gray-100 px-4 py-2 rounded-full text-sm text-gray-600">
            @Model.Count() Orders
        </span>
    </div>

    <!-- EMPTY STATE -->
    @if (!Model.Any())
    {
        <div class="flex flex-col items-center justify-center text-center py-24">

            <!-- Animated Illustration -->
            <img src="https://cdn-icons-png.flaticon.com/512/4076/4076501.png"
                 class="w-40 h-40 mb-6 animate-bounce opacity-90" />

            <h2 class="text-2xl font-semibold text-gray-700">
                No Orders Yet
            </h2>

            <p class="text-gray-500 mt-2">
                You haven’t placed any orders yet.
            </p>

            <a href="/Products"
               class="mt-6 px-6 py-3 rounded-full
                          bg-gradient-to-r from-blue-500 to-indigo-600
                          text-white shadow-lg
                          hover:scale-105 transition">
                Start Shopping
            </a>
        </div>
    }
    else
    {
        <div class="space-y-6">

            @foreach (var item in Model)
            {
                <div class="group bg-white/70 backdrop-blur-lg rounded-2xl p-5
                                    shadow-md hover:shadow-2xl transition duration-300
                                    hover:-translate-y-1">

                    <div class="flex flex-col md:flex-row gap-6 items-center md:items-start">

                        <!-- IMAGE -->
                        <div class="bg-gray-50 p-3 rounded-xl">
                            <img src="@item.ProductImage"
                                 class="w-24 h-24 object-contain transition group-hover:scale-110"
                                 onerror="this.src='/images/no-image.png'" />
                        </div>

                        <!-- DETAILS -->
                        <div class="flex-1 w-full">

                            <h3 class="text-lg font-semibold text-gray-800 mb-2">
                                @item.ProductName
                            </h3>

                            <!-- GRID -->
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm text-gray-600">

                                <p>🧾 <b>#@item.OrderId</b></p>
                                <p>📅 @item.OrderDate.ToString("dd MMM yyyy")</p>
                                <p>📦 Qty: @item.Quantity</p>
                                <p class="font-semibold text-blue-600">₹@item.Total</p>

                            </div>

                            <!-- STATUS -->
                            <div class="mt-3 flex flex-wrap gap-2">

                                <!-- ORDER STATUS -->
                                <span class="px-3 py-1 text-xs rounded-full font-semibold
                                            @(item.OrderStatus.ToLower() == "delivered" ? "bg-green-100 text-green-700 animate-pulse" :
                                                                            item.OrderStatus.ToLower() == "confirmed" ? "bg-blue-100 text-blue-700" :
                                                                            item.OrderStatus.ToLower() == "pending" ? "bg-yellow-100 text-yellow-700 animate-pulse" :
                                                                            "bg-gray-100 text-gray-700")">
                                                                                                    Order Status: @item.OrderStatus
                                                                                                  </span>

                                <!-- PAYMENT -->
                                <span class="px-3 py-1 text-xs rounded-full font-semibold
                                            @(item.PaymentStatus.ToLower() == "completed" ? "bg-green-100 text-green-700" :
                                                                            item.PaymentStatus.ToLower() == "failed" ? "bg-red-100 text-red-700" :
                                                                            "bg-gray-100 text-gray-700")">
                            Payment Status: @item.PaymentStatus
                        </span>

                            </div>
                        </div>

                        <!-- ACTIONS -->
                        <div class="flex flex-col gap-3 w-full md:w-auto">

                    @if (item.PaymentStatus == "Completed")
                            {
                                <button onclick="openInvoice(@item.OrderId)"
                                        class="px-4 py-2 bg-indigo-600 text-white rounded-lg
                                                           hover:bg-indigo-700 transition hover:scale-105">
                                    📄 Invoice
                                </button>
                            }
                            else
                            {
                                <button onclick="showToast()"
                                        class="px-4 py-2 bg-gray-300 text-gray-600 rounded-lg">
                                    📄 Invoice
                                </button>
                            }

                            <a asp-controller="Products"
                               asp-action="Details"
                               asp-route-id="@item.ProductId"
                               class="px-4 py-2 bg-green-600 text-white rounded-lg
                                              hover:bg-green-700 transition hover:scale-105">
                                🔁 Reorder
                            </a>

                        </div>

                    </div>

                </div>
            }
        </div>
    }

</div>

<div id="invoiceModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50">
    <div class="bg-white w-11/12 md:w-3/4 mx-auto mt-10 p-4 rounded-lg relative">

        <button onclick="closeModal()" class="absolute top-2 right-3 text-xl">×</button>

        <iframe id="invoiceFrame" class="w-full h-[80vh] border"></iframe>

    </div>
</div>

<script>
    function openInvoice(orderId) {
        document.getElementById("invoiceModal").classList.remove("hidden");

        document.getElementById("invoiceFrame").src =
            '/Order/Invoice?id=' + orderId;
    }

    function closeModal() {
        document.getElementById("invoiceModal").classList.add("hidden");
    }

    function showInvoiceAlert() {
        let t = document.getElementById("toast");
        t.classList.remove("hidden");
        setTimeout(() => t.classList.add("hidden"), 3000);
    }
</script>

<style>
    @@keyframes fadeUp {
        from

    {
        opacity: 0;
        transform: translateY(15px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .group {
        animation: fadeUp 0.4s ease forwards;
    }
</style>
