@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Invoice</title>

    <style>
        body {
            font-family: "Times New Roman", serif;
            font-size: 13px;
            margin: 0;
            padding: 15px;
        }

        .container {
            max-width: 900px;
            margin: auto;
            border: 1px solid #000;
            padding: 15px;
        }

        /* 🔥 FORCE HIDE BUTTONS */
        .no-print {
            display: block;
        }

        @@media print {
            .no-print {
                display: none !important;
                visibility: hidden !important;
                height: 0 !important;
                overflow: hidden !important;
            }

            .container {
                border: none;
            }

            body {
                padding: 0;
            }
        }

        /* HEADER */
        .header {
            width: 100%;
            border-bottom: 1px solid #000;
            padding-bottom: 10px;
        }

        .header-table {
            width: 100%;
        }

        .logo {
            height: 40px; /* increased from 40px */
            width: auto; /* keeps aspect ratio */
            display: block;
            margin-bottom: 5px;
        }
        .right-header {
            text-align: right;
            vertical-align: top;
        }

        .invoice-title {
            font-size: 15px;
            color: #666;
        }

        /* BILLING */
        .billing-table {
            width: 100%;
            margin-top: 10px;
            border-bottom: 1px solid #000;
            padding-bottom: 10px;
        }

            .billing-table td {
                vertical-align: top;
                width: 50%;
            }

        .right {
            text-align: right;
        }

        /* TABLE */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        table, th, td {
            border: 1px solid #000;
        }

        th, td {
            padding: 8px;
        }

        th {
            background: #f2f2f2;
        }

        /* TOTAL BOX */
        .totals {
            width: 300px;
            margin-left: auto;
            margin-top: 15px;
            border: 1px solid #000;
        }

            .totals div {
                display: flex;
                justify-content: space-between;
                padding: 6px;
                border-bottom: 1px solid #000;
            }

                .totals div:last-child {
                    border-bottom: none;
                }

            /* 🔥 RIGHT ALIGN VALUES */
            .totals span:last-child {
                text-align: right;
                min-width: 100px;
            }

        .grand {
            font-weight: bold;
        }

        /* SIGNATURE */
        .signature {
            margin-top: 25px;
            text-align: right;
        }

            .signature img {
                height: 45px;
            }

        /* FOOTER */
        .footer {
            text-align: center;
            margin-top: 20px;
            font-size: 11px;
            border-top: 1px solid #000;
            padding-top: 8px;
        }

        /* BUTTONS */
        .actions {
            text-align: center;
            margin-top: 20px;
        }

        .btn {
            padding: 6px 12px;
            background: #000;
            color: #fff;
            text-decoration: none;
            margin: 0 5px;
        }

    </style>

    <style>
        .action-buttons {
            display: flex;
            justify-content: flex-end; /* 👉 moves to right */
            gap: 12px;
            margin-bottom: 20px;
        }

        /* Common button style */
        .btn {
            padding: 10px 18px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        /* Print button */
        .print-btn {
            background-color: #6c757d;
            color: white;
        }

            .print-btn:hover {
                background-color: #5a6268;
            }

        /* Download button */
        .download-btn {
            background-color: #007bff;
            color: white;
        }

            .download-btn:hover {
                background-color: #0056b3;
            }
    </style>
</head>

<body>

    <div class="container">

        <!-- HEADER -->
        <div class="header">
            <table class="header-table">
                <tr>
                    <td>
                        <img src="@($"{Context.Request.Scheme}://{Context.Request.Host}/images/sunillogo.png")" class="logo" />

                        <strong>@Model.CompanyName</strong><br />
                        GSTIN: @Model.CompanyGST <br />
                        @Model.CompanyAddress
                    </td>

                    <td class="right-header">
                        <div class="invoice-title">TAX INVOICE</div>
                        Invoice No: @Model.InvoiceNumber<br />
                        Date: @Model.Date.ToString("dd-MM-yyyy")<br />
                        Order ID: #@Model.OrderId
                    </td>
                </tr>
            </table>
        </div>

        <!-- BILLING -->
        <table class="billing-table">
            <tr>
                <td>
                    <strong>Bill To:</strong><br />
                    @Model.CustomerName <br />
                    @Model.Address <br />
                    @Model.City - @Model.Pincode <br />
                    Phone: @Model.Phone
                </td>

                <td class="right">
                    <strong>Payment:</strong> Completed<br />
                    <strong>Status:</strong> Confirmed<br />
                    <strong>Place of Supply:</strong> Andhra Pradesh
                </td>
            </tr>
        </table>

        <!-- ITEMS -->
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Description</th>
                    <th>Qty</th>
                    <th>Unit Price</th>
                    <th>Tax(%)</th>
                    <th>GST Price</th>
                    <th>Total</th>
                </tr>
            </thead>

            <tbody>
                @{
                    int i = 1;
                }

                @foreach (var item in Model.Items)
                {
                    var gstpercentage = item.GSTPercentage;
                    var gstamt = ((item.Price * item.Quantity) * gstpercentage / 100m);
                    var itemtoatl = (item.Price * item.Quantity) + gstamt;

                    <tr>
                        <td>@i</td>
                        <td>@item.ProductName</td>
                        <td>@item.Quantity</td>
                        <td>₹ @item.Price.ToString("0.00")</td>
                        <td>@gstpercentage.ToString("0.00")</td>
                        <td>₹ @gstamt.ToString("0.00")</td>
                        <td>₹ @itemtoatl.ToString("0.00")</td>
                    </tr>

                    i++;
                }
            </tbody>
        </table>

        <!-- TOTAL -->
        <div class="totals">
            <div><span>Sub Total</span><span>₹ @Model.SubTotal</span></div>
            <div><span>GST Total</span><span>₹ @Model.GSTTotal</span></div>
            <div class="grand"><span>Grand Total</span><span>₹ @Model.GrandTotal</span></div>
        </div>

        <!-- SIGNATURE -->
        <div class="signature">
            For @Model.CompanyName<br />
            <img src="@($"{Context.Request.Scheme}://{Context.Request.Host}/images/signature.jpg")" /><br />
            Authorized Signatory
        </div>

        <!-- FOOTER -->
        <div class="footer">
            This is a computer-generated invoice.
        </div>

        <!-- BUTTONS -->
        <div class="no-print">
            @if (!Model.IsPdf)
            {
                <div class="action-buttons">
                    <button onclick="window.print()" class="btn print-btn">
                        🖨 Print
                    </button>

                    <a href="/Order/DownloadInvoice/@Model.OrderId" class="btn download-btn">
                        ⬇ Download
                    </a>
                </div>
            }
        </div>

    </div>

</body>
</html>