@model VivekMedicalProducts.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<script src="https://cdn.tailwindcss.com"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-100 to-gray-200 relative">

    <!-- LOADING OVERLAY -->
    <div id="loader" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50">
        <div class="bg-white p-6 rounded-xl flex flex-col items-center shadow-xl">
            <div class="loader mb-3"></div>
            <p class="text-gray-700 font-semibold">Processing...</p>
        </div>
    </div>

    <!-- SUCCESS SCREEN -->
    <div id="successScreen" class="hidden fixed inset-0 bg-white flex flex-col items-center justify-center z-50">
        <div class="checkmark-circle">
            <div class="checkmark draw"></div>
        </div>
        <h2 class="text-2xl font-bold text-green-600 mt-4">Login Successful</h2>
        <p class="text-gray-500 mt-2">Redirecting...</p>
    </div>

    <!-- LOGIN CARD -->
    <div class="bg-white shadow-2xl rounded-2xl w-full max-w-md p-8">

        <h2 class="text-3xl font-bold text-center text-gray-800 mb-6">
            Welcome Back 👋
        </h2>

        <!-- EMAIL -->
        <div id="emailSection">
            <label class="block text-sm font-medium mb-2">Email Address</label>

            <input type="email" id="email"
                   placeholder="Enter your email"
                   class="w-full border rounded-lg px-3 py-3 mb-4 focus:ring-2 focus:ring-blue-500 outline-none" />

            <button id="sendOtpBtn"
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg font-semibold transition">
                Send OTP
            </button>
        </div>

        <!-- OTP -->
        <div id="otpSection" class="hidden mt-6">

            <p class="text-center text-sm text-gray-600 mb-4">
                Enter OTP sent to your email
            </p>

            <div class="flex justify-between gap-2 mb-4">
                <input class="otp-box" maxlength="1">
                <input class="otp-box" maxlength="1">
                <input class="otp-box" maxlength="1">
                <input class="otp-box" maxlength="1">
                <input class="otp-box" maxlength="1">
                <input class="otp-box" maxlength="1">
            </div>

            <button id="verifyOtpBtn"
                    class="w-full bg-green-600 hover:bg-green-700 text-white py-3 rounded-lg font-semibold transition">
                Verify & Login
            </button>

            <div class="text-center mt-4">
                <span id="timerText" class="text-gray-500 text-sm">
                    Resend in <span id="countdown">60</span>s
                </span>

                <button id="resendOtpBtn"
                        class="hidden text-blue-600 text-sm font-semibold">
                    Resend OTP
                </button>
            </div>
        </div>

    </div>
</div>

<style>
    .otp-box {
        width: 48px;
        height: 52px;
        text-align: center;
        font-size: 20px;
        border: 1px solid #ccc;
        border-radius: 10px;
    }

    .loader {
        border: 4px solid #eee;
        border-top: 4px solid #2563eb;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        100% {
            transform: rotate(360deg);
        }
    }

    /* SUCCESS ANIMATION */
    .checkmark-circle {
        width: 80px;
        height: 80px;
        position: relative;
        display: inline-block;
        vertical-align: top;
    }

        .checkmark-circle .checkmark {
            position: absolute;
            left: 20px;
            top: 40px;
            width: 25px;
            height: 5px;
            background-color: #22c55e;
            transform: rotate(45deg);
            animation: draw 0.5s ease forwards;
        }

    @@keyframes draw {
        from {
            width: 0;
        }

        to {
            width: 25px;
        }
    }
</style>

<script>

    let timer, timeLeft = 60;

    function showLoader() {
        $("#loader").removeClass("hidden");
    }

    function hideLoader() {
        $("#loader").addClass("hidden");
    }

    function showSuccess() {
        $("#successScreen").removeClass("hidden");
    }

    /* SEND OTP */
    $("#sendOtpBtn").click(function () {

        let email = $("#email").val();

        if (!email) {
            Swal.fire("Error", "Enter email", "error");
            return;
        }

        showLoader();

        $.post("/Account/SendOtp", { email: email }, function (res) {

            hideLoader();

            if (res.success) {

                $("#otpSection").removeClass("hidden");
                $(".otp-box").val("");
                $(".otp-box").first().focus();

                startTimer();

                Swal.fire("Success", "OTP sent", "success");

            } else {
                Swal.fire("Error", res.message, "error");
            }
        });
    });

    /* VERIFY OTP */
    $("#verifyOtpBtn").click(function () {

        let email = $("#email").val();
        let otp = "";

        $(".otp-box").each(function () {
            otp += $(this).val();
        });

        if (otp.length !== 6) {
            Swal.fire("Error", "Enter valid OTP", "error");
            return;
        }

        showLoader();

        $.post("/Account/VerifyOtp", { email: email, otp: otp }, function (res) {

            hideLoader();

            if (!res.success) {
                Swal.fire("Error", res.message, "error");
                return;
            }

            showSuccess();

            setTimeout(() => {

                if (!res.isProfileCompleted) {

                    Swal.fire({
                        title: "Complete Profile",
                        icon: "warning",
                        showCancelButton: true,
                        confirmButtonText: "Register",
                        cancelButtonText: "Skip"
                    }).then((r) => {
                        window.location.href = r.isConfirmed ? "/Account/Register" : "/Products";
                    });

                } else {
                    window.location.href = "/Products";
                }

            }, 1500);
        });
    });

    /* RESEND */
    $("#resendOtpBtn").click(function () {

        let email = $("#email").val();

        showLoader();

        $.post("/Account/SendOtp", { email: email }, function (res) {

            hideLoader();

            if (res.success) {
                $(".otp-box").val("");
                $(".otp-box").first().focus();
                startTimer();
                Swal.fire("Success", "OTP resent", "success");
            }
        });
    });

    /* OTP INPUT */
    $(".otp-box").on("input", function () {
        this.value = this.value.replace(/[^0-9]/g, '');
        if (this.value) $(this).next().focus();
    });

    $(".otp-box").on("keydown", function (e) {
        if (e.key === "Backspace" && !this.value)
            $(this).prev().focus();
    });

    /* TIMER */
    function startTimer() {

        clearInterval(timer);
        timeLeft = 60;

        $("#resendOtpBtn").addClass("hidden");
        $("#timerText").removeClass("hidden");

        timer = setInterval(() => {

            timeLeft--;
            $("#countdown").text(timeLeft);

            if (timeLeft <= 0) {
                clearInterval(timer);
                $("#timerText").addClass("hidden");
                $("#resendOtpBtn").removeClass("hidden");
            }

        }, 1000);
    }

</script>