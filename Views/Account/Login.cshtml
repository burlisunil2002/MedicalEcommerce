@model VivekMedicalProducts.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<script src="https://cdn.tailwindcss.com"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-100 to-gray-200 relative">

    <!-- LOADING OVERLAY -->
    <div id="loader" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50">
        <div class="bg-white p-6 rounded-xl flex flex-col items-center shadow-xl">
            <div class="loader mb-3"></div>
            <p class="text-gray-700 font-semibold">Processing...</p>
        </div>
    </div>

    <!-- SUCCESS SCREEN -->
    <div id="successScreen" style="display:none;"
         class="fixed inset-0 bg-white flex flex-col items-center justify-center z-50">

        <div class="checkmark-circle">
            <div class="checkmark"></div>
        </div>

        <h2 class="text-2xl font-bold text-green-600 mt-4">
            Login Successful
        </h2>

        <p class="text-gray-500 mt-2">Redirecting...</p>
    </div>

    <!-- LOGIN CARD -->
    <div class="bg-white shadow-2xl rounded-2xl w-full max-w-md p-8">

        <h2 class="text-3xl font-bold text-center text-gray-800 mb-6">
            Welcome Back 👋
        </h2>

        <!-- EMAIL -->
        <div id="emailSection">
            <label class="block text-sm font-medium mb-2">Email Address</label>

            <input type="email" id="email"
                   placeholder="Enter your email"
                   class="w-full border rounded-lg px-3 py-3 mb-4 focus:ring-2 focus:ring-blue-500 outline-none" />

            <button id="sendOtpBtn"
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg font-semibold transition">
                Send OTP
            </button>
        </div>

        <!-- OTP -->
        <div id="otpSection" class="hidden mt-6">

            <p class="text-center text-sm text-gray-600 mb-4">
                Enter OTP sent to your email
            </p>

            <div class="flex justify-between gap-2 mb-4">
                <input class="otp-box" maxlength="1">
                <input class="otp-box" maxlength="1">
                <input class="otp-box" maxlength="1">
                <input class="otp-box" maxlength="1">
                <input class="otp-box" maxlength="1">
                <input class="otp-box" maxlength="1">
            </div>

            <button id="verifyOtpBtn"
                    class="w-full bg-green-600 hover:bg-green-700 text-white py-3 rounded-lg font-semibold transition">
                Verify & Login
            </button>

            <div class="text-center mt-4">
                <span id="timerText" class="text-gray-500 text-sm">
                    Resend in <span id="countdown">60</span>s
                </span>

                <button id="resendOtpBtn"
                        class="hidden text-blue-600 text-sm font-semibold">
                    Resend OTP
                </button>
            </div>
        </div>

    </div>
</div>

<style>
    /* OTP BOX */
    .otp-box {
        width: 48px;
        height: 52px;
        text-align: center;
        font-size: 20px;
        border: 1px solid #ccc;
        border-radius: 10px;
    }

    /* LOADER */
    .loader {
        border: 4px solid #eee;
        border-top: 4px solid #2563eb;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        100%

    {
        transform: rotate(360deg);
    }

    }

    /* SUCCESS FIX (SMOOTH) */
    #successScreen {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        animation: fadeIn 0.3s ease-in-out;
    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
    }

    to {
        opacity: 1;
    }

    }

    /* CHECK ICON FIX */
    .checkmark-circle {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        border: 4px solid #22c55e;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: scaleIn 0.3s ease-in-out;
    }

    .checkmark {
        position: relative;
        width: 25px;
        height: 50px;
        border-right: 5px solid #22c55e;
        border-bottom: 5px solid #22c55e;
        transform: rotate(45deg);
        animation: drawCheck 0.4s ease forwards;
    }

    @@keyframes drawCheck {
        0%

    {
        width: 0;
        height: 0;
        opacity: 0;
    }

    50% {
        width: 25px;
        height: 0;
        opacity: 1;
    }

    100% {
        width: 25px;
        height: 50px;
        opacity: 1;
    }

    }

    @@keyframes scaleIn {
        from

    {
        transform: scale(0.7);
        opacity: 0;
    }

    to {
        transform: scale(1);
        opacity: 1;
    }

    }
</style>

<script>
    let timer, timeLeft = 60;

    /* LOADER CONTROL */
    function showLoader() {
        $("#loader").fadeIn(150);
    }
    function hideLoader() {
        $("#loader").fadeOut(150);
    }

    /* SUCCESS SCREEN */
       function showSuccess() {
        $("#loader").fadeOut(150);           // hide loader
        $("#successScreen").fadeIn(200);     // ✅ show success properly
    }

        $(document).ready(function () {
        $("#successScreen").hide();   // 🔥 ensure hidden
        $("#loader").hide();
    });

    /* SEND OTP */
    $("#sendOtpBtn").click(function () {

        let email = $("#email").val().trim();

        if (!email) {
            Swal.fire("Error", "Enter email", "error");
            return;
        }

        showLoader();

        $.post("/Account/SendOtp", { email }, function (res) {

            hideLoader();

            if (res.success) {

                $("#otpSection").slideDown(200);
                $(".otp-box").val("");
                $(".otp-box").first().focus();

                startTimer();

                Swal.fire({
                    icon: "success",
                    title: "OTP Sent",
                    timer: 1200,
                    showConfirmButton: false
                });

            } else {
                Swal.fire("Error", res.message, "error");
            }
        });
    });

    /* Verify OTP */

         $("#verifyOtpBtn").click(function () {

        let email = $("#email").val();
        let otp = "";

        $(".otp-box").each(function () {
            otp += $(this).val();
        });

        if (otp.length !== 6) {
            Swal.fire("Error", "Enter valid OTP", "error");
            return;
        }

        showLoader();

        $.post("/Account/VerifyOtp", { email, otp }, function (res) {

            hideLoader();

            if (!res || res.success !== true) {
                Swal.fire("Error", res?.message || "Invalid OTP", "error");
                return;
            }

            let isCompleted = res.isProfileCompleted === true || res.isProfileCompleted === "true";

            if (!isCompleted) {

                // ✅ USER MUST CHOOSE
                Swal.fire({
                    title: "Complete Profile",
                    text: "Please complete your profile to continue",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Register Now",
                    cancelButtonText: "Skip",
                    allowOutsideClick: false,  // 🔥 prevents closing
                    allowEscapeKey: false,     // 🔥 prevents ESC close
                    buttonsStyling: false,
                    customClass: {
                        confirmButton: "bg-blue-600 text-white px-4 py-2 rounded-lg",
                        cancelButton: "bg-gray-500 text-white px-4 py-2 rounded-lg ml-2"
                    }
                }).then((r) => {

                    if (r.isConfirmed) {
                        window.location.href = "/Account/Register";
                    } else {
                        window.location.href = "/Products";
                    }

                });

            } else {

                // ✅ Direct redirect if profile completed
                window.location.href = "/Products";
            }

        }).fail(function () {
            hideLoader();
            Swal.fire("Error", "Server error", "error");
        });

    });

    /* RESEND OTP */
    $("#resendOtpBtn").click(function () {

        let email = $("#email").val();

        showLoader();

        $.post("/Account/SendOtp", { email }, function (res) {

            hideLoader();

            if (res.success) {
                $(".otp-box").val("");
                $(".otp-box").first().focus();
                startTimer();

                Swal.fire({
                    icon: "success",
                    title: "OTP Resent",
                    timer: 1200,
                    showConfirmButton: false
                });
            }
        });
    });

    /* OTP INPUT UX */
    $(".otp-box").on("input", function () {
        this.value = this.value.replace(/[^0-9]/g, '');
        if (this.value) $(this).next().focus();
    });

    $(".otp-box").on("keydown", function (e) {
        if (e.key === "Backspace" && !this.value)
            $(this).prev().focus();
    });

    /* TIMER */
    function startTimer() {

        clearInterval(timer);
        timeLeft = 60;

        $("#resendOtpBtn").addClass("hidden");
        $("#timerText").removeClass("hidden");

        timer = setInterval(() => {

            timeLeft--;
            $("#countdown").text(timeLeft);

            if (timeLeft <= 0) {
                clearInterval(timer);
                $("#timerText").addClass("hidden");
                $("#resendOtpBtn").removeClass("hidden");
            }

        }, 1000);
    }
</script>