@model VivekMedicalProducts.Models.ProductModel

@Html.AntiForgeryToken()

@{
    var discount = Model.DiscountPercentage ?? 0;

    var isDealActive = Model.IsHotDeal
        && Model.DealEndDate.HasValue
        && Model.DealEndDate > DateTime.UtcNow
        && discount > 0;

    var finalPrice = isDealActive
        ? Model.Price - (Model.Price * discount / 100)
        : Model.Price;
}

<div class="min-h-screen bg-gradient-to-br from-gray-100 via-white to-gray-200 py-10 px-4">

    <div class="max-w-6xl mx-auto">

        <!-- 🔹 MAIN CARD -->
        <div class="bg-white rounded-3xl shadow-xl p-6 sm:p-10">

            <div class="grid lg:grid-cols-2 gap-10 items-center">

                <!-- 🔹 IMAGE -->
                <div class="relative rounded-2xl overflow-hidden bg-gray-50 border">

                    <!-- 🔥 HOT DEAL BADGE -->
                    @if (isDealActive)
                    {
                        <span class="absolute top-3 left-3 bg-red-500 text-white text-xs px-3 py-1 rounded shadow">
                            🔥 @discount% OFF
                        </span>
                    }

                    <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/no-image.png" : Model.ImageUrl)"
                         class="w-full h-[320px] sm:h-[420px] object-contain p-4" />
                </div>

                <!-- 🔹 DETAILS -->
                <div class="flex flex-col justify-between space-y-6">

                    <!-- TITLE -->
                    <div>
                        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">
                            @Model.Name
                        </h1>

                        <p class="text-gray-600 mt-3 text-sm leading-relaxed">
                            @Model.Description
                        </p>
                    </div>

                    <!-- 🔹 PRICE -->
                    @if (Model.PriceType?.ToLower() == "normal")
                    {
                        <div>

                            @if (isDealActive)
                            {
                                <!-- HOT DEAL PRICE -->
                                <div class="flex items-center gap-3">

                                    <span class="text-3xl font-bold text-green-600">
                                        ₹ @finalPrice.ToString("N0")
                                    </span>

                                    <span class="line-through text-gray-400 text-lg">
                                        ₹ @Model.Price.ToString("N0")
                                    </span>

                                    <span class="text-red-500 text-sm font-semibold">
                                        @discount% OFF
                                    </span>

                                </div>

                                <p class="text-xs text-red-500 mt-1">
                                    ⚡ Limited time deal!
                                </p>
                            }
                            else
                            {
                                <!-- NORMAL PRICE -->
                                <span class="text-3xl font-bold text-green-600">
                                    ₹ @Model.Price.ToString("N0")
                                </span>
                            }

                        </div>
                    }
                    else
                    {
                        <p class="text-lg font-semibold text-orange-500">
                            📩 Price on Request
                        </p>
                    }

                    <!-- 🔹 ACTIONS -->
                    <div class="pt-4">

                        @if (Model.PriceType?.ToLower() == "normal")
                        {
                            <div class="flex flex-col sm:flex-row gap-4">

                                <!-- CART -->
                                <div class="cart-area flex items-center justify-between
                                                bg-gray-100 rounded-xl px-2 w-full sm:w-auto"
                                     data-id="@Model.Id">

                                    <!-- ADD -->
                                    <button class="add-cart-btn w-full sm:w-auto px-6 py-3
                                                       bg-blue-600 text-white rounded-xl
                                                       hover:bg-blue-700 transition">
                                        🛒 Add to Cart
                                    </button>

                                    <!-- QTY -->
                                    <div class="qty-controller hidden items-center">

                                        <button class="minus px-4 py-3 text-lg hover:bg-gray-200 rounded-l-xl">−</button>

                                        <span class="qty px-6 font-semibold">1</span>

                                        <button class="plus px-4 py-3 text-lg hover:bg-gray-200 rounded-r-xl">+</button>

                                    </div>
                                </div>

                                <!-- VIEW DOC -->
                                @if (!string.IsNullOrEmpty(Model.QuotationUrl))
                                {
                                    <a href="https://docs.google.com/gview?url=@Model.QuotationUrl&embedded=true"
                                       target="_blank"
                                       class="w-full sm:w-auto text-center px-6 py-3
                                                      bg-black text-white rounded-xl hover:bg-gray-900 transition">
                                        📄 View Document
                                    </a>
                                }

                            </div>
                        }
                        else
                        {
                            <div class="flex flex-col sm:flex-row gap-4">

                                <a asp-controller="Home"
                                   asp-action="Enquiry"
                                   asp-route-productId="@Model.Id"
                                   class="w-full text-center px-6 py-3 bg-orange-500 text-white rounded-xl hover:bg-orange-600 transition">
                                    📞 Request Quote
                                </a>

                                @if (!string.IsNullOrEmpty(Model.QuotationUrl))
                                {
                                    <a href="https://docs.google.com/gview?url=@Model.QuotationUrl&embedded=true"
                                       target="_blank"
                                       class="w-full text-center px-6 py-3 bg-black text-white rounded-xl hover:bg-gray-900 transition">
                                        📄 View Document
                                    </a>
                                }

                            </div>
                        }

                    </div>

                </div>

            </div>

        </div>

    </div>
</div>