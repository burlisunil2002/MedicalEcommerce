@model VivekMedicalProducts.Models.ProductModel

<div class="min-h-screen bg-gradient-to-br from-gray-100 via-white to-gray-200 py-10 px-4">

    <div class="max-w-6xl mx-auto">

        <!-- GLASS CARD -->
        <div class="backdrop-blur-xl bg-white/70 border border-white/40 rounded-3xl shadow-2xl p-6 sm:p-10">

            <div class="grid lg:grid-cols-2 gap-10 items-center">

                <!-- 🔹 IMAGE -->
                <div class="relative rounded-2xl overflow-hidden bg-white/40 backdrop-blur-lg border border-white/30">

                    <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/no-image.png" : Model.ImageUrl)"
                         class="w-full h-[300px] sm:h-[400px] object-cover transition duration-500 hover:scale-110" />

                    <!-- subtle overlay -->
                    <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"></div>
                </div>

                <!-- 🔹 DETAILS -->
                <div class="flex flex-col justify-between space-y-6">

                    <!-- TITLE -->
                    <div>
                        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900">
                            @Model.Name
                        </h1>

                        <p class="text-gray-600 mt-3 text-sm sm:text-base leading-relaxed">
                            @Model.Description
                        </p>
                    </div>

                    <!-- PRICE -->
                    @if (Model.PriceType?.ToLower() == "normal")
                    {
                        <div>
                            <p class="text-3xl font-bold text-green-600">
                                ₹ @Model.Price.ToString("N2")
                            </p>

                            @if (Model.GSTPercentage > 0)
                            {
                                <p class="text-sm text-gray-500 mt-1">
                                    Inclusive of GST @Model.GSTPercentage%
                                </p>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-lg font-semibold text-orange-500">
                            Price on Request
                        </p>
                    }

                    <!-- 🔹 ACTIONS -->
                    <div class="pt-4">

                        @if (Model.PriceType?.ToLower() == "normal")
                        {
                            <div class="flex flex-col sm:flex-row gap-4">

                                <!-- CART AREA -->
                                <div class="cart-area flex items-center justify-between sm:justify-start
                                                bg-white/60 backdrop-blur-lg border border-white/30
                                                rounded-xl px-2 w-full sm:w-auto shadow-sm"
                                     data-id="@Model.Id">

                                    <!-- ADD -->
                                    <button class="add-cart-btn w-full sm:w-auto px-6 py-3
                                                       bg-blue-600 text-white rounded-xl
                                                       hover:bg-blue-700 transition">
                                        Add to Cart
                                    </button>

                                    <!-- QTY -->
                                    <div class="qty-controller hidden items-center">

                                        <button class="minus px-4 py-3 text-lg hover:bg-gray-200 rounded-l-xl">−</button>

                                        <span class="qty px-6 font-semibold">1</span>

                                        <button class="plus px-4 py-3 text-lg hover:bg-gray-200 rounded-r-xl">+</button>

                                    </div>
                                </div>

                                <!-- VIEW -->
                                @if (!string.IsNullOrEmpty(Model.QuotationUrl))
                                {
                                    <a href="https://docs.google.com/gview?url=@Model.QuotationUrl&embedded=true"
                                       target="_blank"
                                       class="w-full sm:w-auto text-center px-6 py-3
                                                      bg-black text-white rounded-xl hover:bg-gray-900 transition">
                                        View Document
                                    </a>
                                }

                            </div>
                        }
                        else
                        {
                            <div class="flex flex-col sm:flex-row gap-4">

                                <a asp-controller="Home"
                                   asp-action="Enquiry"
                                   asp-route-productId="@Model.Id"
                                   class="w-full text-center px-6 py-3 bg-orange-500 text-white rounded-xl hover:bg-orange-600 transition">
                                    Request Quote
                                </a>

                                <a href="https://docs.google.com/gview?url=@Model.QuotationUrl&embedded=true"
                                   target="_blank"
                                   class="w-full text-center px-6 py-3 bg-black text-white rounded-xl hover:bg-gray-900 transition">
                                    View Document
                                </a>

                            </div>
                        }

                    </div>

                </div>

            </div>
        </div>

    </div>
</div>

<!-- 🔹 SCRIPT -->
<script>
    $(document).ready(function () {

        loadCartCount();

        // ADD TO CART → SWITCH UI
       $(".add-cart-btn").click(function () {

            var parent = $(this).closest(".cart-area");
            var productId = parent.data("id");
            var button = $(this);

            button.prop("disabled", true).text("Adding...");

            parent.find(".qty-controller").removeClass("hidden").addClass("flex");
            button.hide();

            $.post("/Cart/AddToCart", { productId: productId }, function () {
                loadCartCount();

                setTimeout(() => {
                    button.text("Add to Cart").prop("disabled", false);
                }, 300);
            });
        });

        // PLUS
        $(".plus").click(function () {

            var parent = $(this).closest(".cart-area");
            var qtySpan = parent.find(".qty");

            var qty = parseInt(qtySpan.text()) + 1;
            qtySpan.text(qty);

            var productId = parent.data("id");

            $.post("/Cart/AddToCart", { productId: productId }, function () {
                loadCartCount();
            });
        });

        // MINUS
        $(".minus").click(function () {

            var parent = $(this).closest(".cart-area");
            var qtySpan = parent.find(".qty");

            var qty = parseInt(qtySpan.text());
            var productId = parent.data("id");

            if (qty > 1) {

                qty--;
                qtySpan.text(qty);

                $.post("/Cart/DecreaseQuantity", { productId: productId }, function () {
                    loadCartCount();
                });

            } else {

                $.post("/Cart/Remove", { productId: productId }, function () {

                    parent.find(".qty-controller").addClass("hidden").removeClass("flex");
                    parent.find(".add-cart-btn").show();

                    loadCartCount();
                });
            }
        });

    });

    // CART COUNT
    function loadCartCount() {
        $.get("/Cart/GetCartCount", function (data) {
            $("#cartCount").text(data);
        });
    }
</script>