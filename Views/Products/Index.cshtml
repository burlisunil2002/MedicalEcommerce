@model IEnumerable<VivekMedicalProducts.ViewModels.ProductViewModel>

<form method="post">
    @Html.AntiForgeryToken()
</form>

@{
    var selectedCategory = Context.Request.Query["category"].ToString();
    bool isCategoryPage = !string.IsNullOrEmpty(selectedCategory);
}
@{
    var now = DateTime.UtcNow;

    var hotDeals = Model
        .Where(p => p.IsHotDeal
            && p.DealEndDate.HasValue
            && p.DealEndDate > now)
        .ToList();
}

@if (!isCategoryPage)
{

<!-- ✅ HERO -->
<div class="swiper mySwiper mb-8">
    <div class="swiper-wrapper">

        <div class="swiper-slide bg-blue-600 text-white text-center py-14">
            <h1 class="text-3xl font-bold">Medical Products Store</h1>
            <p class="text-sm mt-2">Trusted Healthcare Equipment</p>
        </div>

        <div class="swiper-slide bg-blue-500 text-white text-center py-14">
            <h1 class="text-3xl font-bold">Quality Devices</h1>
            <p class="text-sm mt-2">Best price guaranteed</p>
        </div>

        <div class="swiper-slide bg-blue-700 text-white text-center py-14">
            <h1 class="text-3xl font-bold">Hospital Equipment</h1>
            <p class="text-sm mt-2">Bulk orders available</p>
        </div>

    </div>

    <div class="swiper-pagination"></div>
</div>

<!-- ✅ CATEGORY (UPGRADED) -->
<div class="max-w-7xl mx-auto mt-6 px-4">

    <!-- HEADER -->
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold flex items-center gap-2">
            🏥 Shop by Category
        </h2>
        <span class="text-xs text-gray-500">Swipe →</span>
    </div>

    <!-- HORIZONTAL SCROLL -->
    <div class="flex gap-4 overflow-x-auto pb-3 scroll-smooth">

        @foreach (var cat in ViewBag.Categories)
        {
            <a asp-controller="Products"
               asp-action="Index"
               asp-route-category="@cat.Name"
               class="min-w-[90px] sm:min-w-[110px] bg-white border border-gray-100
                          rounded-xl p-3 text-center shadow-sm
                          hover:shadow-xl hover:-translate-y-1
                          transition duration-300 relative group">

                <!-- ICON BG -->
                <div class="absolute inset-0 bg-gradient-to-br from-blue-50 to-transparent opacity-0 group-hover:opacity-100 rounded-xl transition"></div>

                <!-- IMAGE -->
                <div class="h-14 flex items-center justify-center mb-2 relative z-10">
                    <img src="@(string.IsNullOrEmpty(cat.ImageUrl) ? "/images/no-image.png" : cat.ImageUrl)"
                         class="max-h-12 object-contain transition duration-300 group-hover:scale-110" />
                </div>

                <!-- NAME -->
                <p class="text-xs font-medium text-gray-700 truncate relative z-10 group-hover:text-blue-600">
                    @cat.Name
                </p>

            </a>
        }

    </div>
</div>

<div class="max-w-7xl mx-auto px-4 mt-6">

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">

        <div class="bg-white p-4 rounded-xl shadow-sm">
            <p class="text-blue-600 text-lg">✔</p>
            <p class="text-xs mt-1">100% Genuine</p>
        </div>

        <div class="bg-white p-4 rounded-xl shadow-sm">
            <p class="text-blue-600 text-lg">🚚</p>
            <p class="text-xs mt-1">Fast Delivery</p>
        </div>

        <div class="bg-white p-4 rounded-xl shadow-sm">
            <p class="text-blue-600 text-lg">💰</p>
            <p class="text-xs mt-1">Best Pricing</p>
        </div>

        <div class="bg-white p-4 rounded-xl shadow-sm">
            <p class="text-blue-600 text-lg">📞</p>
            <p class="text-xs mt-1">24/7 Support</p>
        </div>

    </div>

</div>


@if (hotDeals.Any())
{
    <div class="max-w-7xl mx-auto mt-10 px-4">

        <h2 class="text-xl font-bold text-red-500 mb-4">🔥 Hot Deals</h2>

        <div class="flex gap-4 overflow-x-auto pb-4">

            @foreach (var product in hotDeals)
            {
                var discount = product.DiscountPercentage ?? 0;
                var finalPrice = product.Price - (product.Price * discount / 100);

                <div class="min-w-[250px] bg-white rounded-xl shadow hover:shadow-xl transition relative">

                    <!-- Discount -->
                    <span class="absolute top-2 left-2 bg-red-500 text-white text-xs px-2 py-1 rounded">
                        @discount% OFF
                    </span>

                    <!-- Timer -->
                    <span class="absolute top-2 right-2 bg-black text-white text-xs px-2 py-1 rounded">
                            <span class="countdown" data-date="@product.DealEndDate?.ToString("yyyy-MM-ddTHH:mm:ss")"></span>
                    </span>

                    <img src="@product.ImageUrl" class="h-36 w-full object-contain p-2" />

                    <div class="p-3">
                        <p class="text-sm font-semibold">@product.Name</p>

                        <div class="flex gap-2 mt-1">
                            <span class="text-green-600 font-bold">₹@finalPrice</span>
                            <span class="line-through text-gray-400 text-xs">₹@product.Price</span>
                        </div>

                        <!-- Cart -->
                        <div class="cart-area mt-2" data-id="@product.Id">

                                <button type="button"
                                        class="add-cart-btn w-full bg-red-500 text-white py-2 rounded text-sm">
                                    Grab Deal
                                </button>

                            <div class="qty-controller hidden flex items-center justify-between mt-2 bg-gray-100 rounded">
                                <button class="minus px-3 py-1">−</button>
                                <span class="qty">1</span>
                                <button class="plus px-3 py-1">+</button>
                            </div>

                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
}

}

<!-- ✅ PRODUCTS -->
<div class="max-w-7xl mx-auto mt-10 px-4 pb-12">

    <h2 class="text-xl font-semibold mb-5">Our Products</h2>

    <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

        @foreach (var product in Model)
        {
            var isNormal = product.PriceType?.ToLower() == "normal";
            var discount = product.DiscountPercentage ?? 0;
            var finalPrice = product.Price - (product.Price * discount / 100);

            <div class="bg-white rounded-2xl border hover:shadow-2xl transition duration-300 overflow-hidden flex flex-col relative group">

                <!-- 🔥 HOT DEAL BADGE -->
                @if (product.IsHotDeal
                            && product.DealEndDate.HasValue
                            && product.DealEndDate > DateTime.UtcNow
                            && discount > 0)
                {
                    <span class="absolute top-2 left-2 bg-red-500 text-white text-xs px-2 py-1 rounded shadow">
                        🔥 @discount% OFF
                    </span>

                    <span class="absolute top-2 right-2 bg-black text-white text-xs px-2 py-1 rounded shadow">
                        <span class="countdown" data-date="@product.DealEndDate?.ToString("yyyy-MM-ddTHH:mm:ss")"></span>
                    </span>
                }

                <!-- 🖼 IMAGE -->
                <a asp-controller="Products"
                   asp-action="Details"
                   asp-route-id="@product.Id"
                   class="bg-gray-50 h-48 flex items-center justify-center overflow-hidden">

                    <img src="@product.ImageUrl"
                         class="max-h-40 object-contain transition-none" />
                </a>

                <!-- 📦 CONTENT -->
                <div class="p-4 flex flex-col flex-grow">

                    <!-- PRODUCT NAME -->
                    <h4 class="text-sm font-semibold text-gray-800 line-clamp-2 min-h-[40px]">
                        @product.Name
                    </h4>

                    <!-- 💰 PRICE / REQUEST -->
                    <div class="mt-2">

                        @if (isNormal)
                        {
                            <div>
                                <span class="text-blue-600 font-bold text-lg">
                                    ₹@finalPrice.ToString("N0")
                                </span>

                                @if (discount > 0)
                                {
                                    <span class="line-through text-gray-400 text-sm ml-2">
                                        ₹@product.Price.ToString("N0")
                                    </span>

                                    <span class="ml-2 text-green-600 text-xs font-semibold">
                                        @discount% OFF
                                    </span>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-orange-500 text-sm font-medium flex items-center gap-1">
                                📩 Price on Request
                            </p>
                        }

                    </div>

                    <!-- ⚡ URGENCY -->
                    @if (product.IsHotDeal)
                    {
                        <p class="text-xs text-red-500 mt-1">
                            ⚡ Limited time deal!
                        </p>
                    }

                    <!-- 🛒 ACTION -->
                    <div class="mt-auto pt-4">

                        @if (isNormal)
                        {
                            <div class="cart-area" data-id="@product.Id">

                                <!-- ADD BUTTON -->
                                <button type="button"
                                        class="add-cart-btn w-full bg-blue-600 text-white py-2 rounded-lg text-sm hover:bg-blue-700 transition flex items-center justify-center gap-2">
                                    🛒 Add to Cart
                                </button>

                                <!-- QTY -->
                                <div class="qty-controller hidden items-center justify-between mt-2 bg-gray-100 rounded-lg">

                                    <button class="minus px-3 py-2 text-lg hover:bg-gray-200 rounded-l">−</button>
                                    <span class="qty font-medium">1</span>
                                    <button class="plus px-3 py-2 text-lg hover:bg-gray-200 rounded-r">+</button>

                                </div>

                            </div>
                        }
                        else
                        {
                            <a asp-controller="Home"
                               asp-action="Enquiry"
                               asp-route-productId="@product.Id"
                               class="block text-center bg-orange-500 text-white py-2 rounded-lg text-sm hover:bg-orange-600 transition flex items-center justify-center gap-2">
                                📞 Request Quote
                            </a>
                        }

                    </div>

                </div>
            </div>
        }

    </div>

</div>

<!-- ✅ STYLES -->
<style>
    .filter-pill {
        padding: 6px 14px;
        border-radius: 999px;
        background: #e5e7eb;
        font-size: 13px;
        transition: 0.2s;
    }

        .filter-pill:hover {
            background: #2563eb;
            color: white;
        }

    .active-pill {
        background: #2563eb;
        color: white;
    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(-8px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .animate-fadeIn {
        animation: fadeIn 0.3s ease-in-out;
    }

    ::-webkit-scrollbar {
        height: 6px;
    }

    ::-webkit-scrollbar-thumb {
        background: #cbd5f5;
        border-radius: 10px;
    }
</style>

<!-- ✅ SCRIPTS -->

<script>


    // ================= FILTER =================
    $(document).on("click", ".filter-pill", function () {

        $(".filter-pill").removeClass("active-pill");
        $(this).addClass("active-pill");

        var category = $(this).data("category");

        if (!category || category === "all") {
            $(".product-card").show();
        } else {
            $(".product-card").hide();
            $('.product-card[data-category="' + category + '"]').show();
        }
    });


    // ================= CLOSE ALERT =================
    function closePaymentBox(){
        $("#paymentSuccessBox").fadeOut();
    }


    // ================= SWIPER =================
    var swiper = new Swiper(".mySwiper", {
        loop: true,
        autoplay: { delay: 3000 },
        pagination: { el: ".swiper-pagination", clickable: true }
    });


    // ================= COUNTDOWN =================
       setInterval(() => {
        document.querySelectorAll(".countdown").forEach(el => {

            const endDate = el.dataset.date;

            if (!endDate) {
                el.innerText = "No Deal";
                return;
            }

            const end = new Date(endDate);
            const now = new Date();

            if (isNaN(end)) {
                el.innerText = "Invalid";
                return;
            }

            const diff = end - now;

            // 🔥 EXPIRED FIX
            if (diff <= 0) {
                el.innerText = "Expired";

                // ❌ disable button
                const card = el.closest(".min-w-[250px], .bg-white");
                if (card) {
                    const btn = card.querySelector(".add-cart-btn");
                    if (btn) {
                        btn.innerText = "Deal Ended";
                        btn.disabled = true;
                        btn.classList.remove("bg-red-500");
                        btn.classList.add("bg-gray-400");
                    }
                }

                return;
            }

            const h = Math.floor(diff / 3600000);
            const m = Math.floor((diff % 3600000) / 60000);
            const s = Math.floor((diff % 60000) / 1000);

            el.innerText = `${h}h ${m}m ${s}s`;
        });
    }, 1000);

</script>
