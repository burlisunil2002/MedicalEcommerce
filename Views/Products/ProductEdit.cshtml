@model VivekMedicalProducts.Models.ProductModel

<div asp-validation-summary="All" class="text-red-500 mb-4"></div>

<div class="min-h-screen bg-gradient-to-br from-gray-100 to-gray-200 py-10 px-4">

    <div class="max-w-5xl mx-auto bg-white shadow-xl rounded-2xl p-8">

        <!-- HEADER -->
        <div class="flex justify-between items-center mb-8">
            <h2 class="text-2xl font-bold text-gray-800">
                ✏️ Edit Product
            </h2>

            <a asp-controller="Products"
               asp-action="ProductManagement"
               class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition">
                ← Back
            </a>
        </div>

        <!-- FORM -->
        <form asp-action="ProductEdit" method="post" enctype="multipart/form-data">

            <input type="hidden" asp-for="Id" />

            <div class="grid md:grid-cols-2 gap-6">

                <!-- PRODUCT NAME -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                        Product Name
                    </label>
                    <input asp-for="Name"
                           class="w-full px-4 py-2 border rounded-xl focus:ring-2 focus:ring-blue-400 outline-none" />
                </div>

                <!-- PRICE -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                        Price
                    </label>
                    <input asp-for="Price"
                           class="w-full px-4 py-2 border rounded-xl focus:ring-2 focus:ring-blue-400 outline-none" />
                </div>

                <!-- DESCRIPTION -->
                <div class="md:col-span-2">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                        Description
                    </label>
                    <textarea asp-for="Description"
                              rows="3"
                              class="w-full px-4 py-2 border rounded-xl focus:ring-2 focus:ring-blue-400 outline-none"></textarea>
                </div>

                <!-- GST -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                        GST (%)
                    </label>
                    <input asp-for="GSTPercentage"
                           class="w-full px-4 py-2 border rounded-xl focus:ring-2 focus:ring-blue-400 outline-none" />
                </div>

                <!-- IMAGE PREVIEW + UPLOAD -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                        Product Image
                    </label>

                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <img src="@Model.ImagePath"
                             class="h-24 mb-3 rounded-lg border object-cover" />
                    }

                    <input type="file" name="ImageFile"
                           class="w-full text-sm bg-gray-50 border rounded-xl p-2 cursor-pointer" />
                </div>

                <!-- QUOTATION PREVIEW + UPLOAD -->
                <div class="md:col-span-2">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                        Quotation (PDF)
                    </label>

                    @if (!string.IsNullOrEmpty(Model.QuotationPath))
                    {
                        <a asp-controller="Products"
                           asp-action="ViewQuotation"
                           asp-route-id="@Model.Id"
                           target="_blank"
                           class="inline-block mb-3 text-blue-600 underline text-sm">
                            📄 View Current Quotation
                        </a>
                    }

                    <input type="file" name="QuotationFile"
                           class="w-full text-sm bg-gray-50 border rounded-xl p-2 cursor-pointer" />
                </div>

            </div>

            <!-- ACTION BUTTON -->
            <div class="mt-8 flex justify-end">
                <button type="submit"
                        class="px-6 py-3 bg-blue-600 text-white rounded-xl shadow hover:bg-blue-700 transition">
                    💾 Update Product
                </button>
            </div>

        </form>

    </div>

</div>