@model VivekMedicalProducts.Models.ProductModel

<div asp-validation-summary="All" class="text-red-500 mb-4"></div>

<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-gray-100 py-10 px-4">

    <div class="max-w-5xl mx-auto bg-white shadow-2xl rounded-3xl p-8">

        <!-- HEADER -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-3">
            <h2 class="text-2xl font-bold text-gray-800">
                ✏️ Edit Product
            </h2>

            <a asp-controller="Products"
               asp-action="ProductManagement"
               class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition">
                ← Back
            </a>
        </div>

        <!-- FORM -->
        <form asp-controller="Products"
              asp-action="ProductEdit"
              method="post"
              enctype="multipart/form-data">

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImageUrl" />
            <input type="hidden" asp-for="QuotationUrl" />

            <!-- GRID -->
            <div class="grid md:grid-cols-2 gap-6">

                <!-- NAME -->
                <div>
                    <label class="label">Product Name</label>
                    <input asp-for="Name" class="input" />
                </div>

                <!-- CATEGORY -->
                <div>
                    <label class="label">Category</label>
                    <input asp-for="Category" class="input" />
                </div>

                <!-- PRICE TYPE -->
                <div>
                    <label class="label">Price Type</label>
                    <input asp-for="PriceType" class="input" />
                </div>

                <!-- PRICE -->
                <div>
                    <label class="label">Price</label>
                    <input asp-for="Price" class="input" />
                </div>

                <!-- GST -->
                <div>
                    <label class="label">GST (%)</label>
                    <input asp-for="GSTPercentage" class="input" />
                </div>

                <!-- 🔥 HOT DEAL TOGGLE -->
                <div class="flex items-center gap-3 mt-6">
                    <input asp-for="IsHotDeal" class="h-5 w-5" id="hotDealToggle" />
                    <span class="text-sm font-medium text-gray-700">
                        🔥 Mark as Hot Deal
                    </span>
                </div>

                <!-- DISCOUNT -->
                <div id="discountSection">
                    <label class="label">Discount (%)</label>
                    <input asp-for="DiscountPercentage"
                           type="number"
                           step="0.01"
                           class="input" />
                </div>

                <!-- 🔥 DEAL DATE (IMPORTANT FIX) -->
                <div id="dateSection">
                    <label class="label">Deal End Date</label>
                    <input asp-for="DealEndDate"
                           type="datetime-local"
                           value="@Model.DealEndDate?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm")"
                           class="input" />
                </div>

                <!-- DESCRIPTION -->
                <div class="md:col-span-2">
                    <label class="label">Description</label>
                    <textarea asp-for="Description" rows="3" class="input"></textarea>
                </div>

                <!-- IMAGE -->
                <div>
                    <label class="label">Product Image</label>

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl"
                             class="h-24 mb-3 rounded-xl border object-cover shadow-sm" />
                    }

                    <input type="file" name="imageFile" class="file-input" />
                </div>

                <!-- PDF -->
                <div>
                    <label class="label">Quotation (PDF)</label>

                    @if (!string.IsNullOrEmpty(Model.QuotationUrl))
                    {
                        <a href="https://docs.google.com/gview?url=@Model.QuotationUrl&embedded=true"
                           target="_blank"
                           class="block text-center px-4 py-2 bg-black text-white rounded-xl mb-3 hover:bg-gray-800 transition">
                            View Document
                        </a>
                    }

                    <input type="file" name="quotationFile" class="file-input" />
                </div>

            </div>

            <!-- BUTTON -->
            <div class="flex justify-end pt-6 border-t">
                <button type="submit"
                        class="px-6 py-3 bg-blue-600 text-white rounded-xl shadow hover:bg-blue-700 transition transform hover:scale-105">
                    💾 Update Product
                </button>
            </div>

        </form>

    </div>
</div>

<!-- 🎨 COMMON STYLES -->
<style>
    .label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
    }

    .input {
        width: 100%;
        padding: 10px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
        transition: 0.2s;
    }

        .input:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 2px #bfdbfe;
        }

    .file-input {
        width: 100%;
        padding: 8px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
        background: #f9fafb;
        cursor: pointer;
    }
</style>