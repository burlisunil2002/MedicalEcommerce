@model IEnumerable<VivekMedicalProducts.Models.ProductModel>

<div class="min-h-screen bg-gray-100 p-6">

    <!-- HEADER -->
    <div class="max-w-7xl mx-auto mb-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">

        <h2 class="text-2xl font-bold text-gray-800">
            📦 Product Management
        </h2>

        <div class="flex gap-3">
            <a asp-controller="Admin"
               asp-action="AdminHome"
               class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition">
                ← Back
            </a>

            <a asp-controller="Products"
               asp-action="AddProducts"
               class="px-4 py-2 bg-blue-600 text-white rounded-lg shadow hover:bg-blue-700 transition">
                + Add Product
            </a>
        </div>
    </div>

    <!-- TABLE CARD -->
    <div class="max-w-7xl mx-auto bg-white rounded-2xl shadow-lg overflow-hidden">

        <div class="overflow-x-auto">

            <table class="min-w-full text-sm text-left text-gray-600">

                <!-- HEADER -->
                <thead class="bg-gray-100 text-gray-700 uppercase text-xs">
                    <tr>
                        <th class="px-6 py-4">Image</th>
                        <th class="px-6 py-4">Name</th>
                        <th class="px-6 py-4">Price</th>
                        <th class="px-6 py-4">GST</th>
                        <th class="px-6 py-4">Quotation</th>
                        <th class="px-6 py-4 text-center">Actions</th>
                    </tr>
                </thead>

                <!-- BODY -->
                <tbody class="divide-y">

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-10 text-gray-500">
                                No products available
                            </td>
                        </tr>
                    }

                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50 transition">

                            <!-- IMAGE -->
                            <td class="px-6 py-4">
                                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.png" : item.ImageUrl)"
                                     class="h-14 w-14 object-cover rounded-lg border" />
                            </td>

                            <!-- NAME -->
                            <td class="px-6 py-4 font-medium text-gray-800">
                                @item.Name
                            </td>

                            <!-- PRICE -->
                            <td class="px-6 py-4 text-green-600 font-semibold">
                                @if (item.PriceType?.ToLower() == "normal")
                                {
                                    <span>₹ @item.Price.ToString("N2")</span>
                                }
                                else
                                {
                                    <span class="text-red-500">Ask Price</span>
                                }
                            </td>

                            <!-- GST -->
                            <td class="px-6 py-4">
                                @item.GSTPercentage %
                            </td>

                            <!-- QUOTATION -->
                            <td class="px-6 py-4">
                                @if (!string.IsNullOrEmpty(item.QuotationUrl))
                                {
                                    <a asp-controller="Products"
                                       asp-action="ViewQuotation"
                                       asp-route-id="@item.Id"
                                       target="_blank"
                                       class="text-blue-600 hover:underline">
                                        View
                                    </a>
                                }
                                else
                                {
                                    <span class="text-gray-400">N/A</span>
                                }
                            </td>

                            <!-- ACTIONS -->
                            <td class="px-6 py-4">
                                <div class="flex justify-center gap-2">

                                    <!-- EDIT -->
                                    <a asp-action="ProductEdit"
                                       asp-route-id="@item.Id"
                                       class="px-3 py-1 bg-yellow-400 text-white rounded-lg hover:bg-yellow-500 transition text-xs">
                                        Edit
                                    </a>

                                    <!-- DELETE -->
                                    <form asp-action="Delete"
                                          asp-controller="Products"
                                          method="post"
                                          onsubmit="return confirm('Are you sure you want to delete this product?')">

                                        <input type="hidden" name="id" value="@item.Id" />

                                        <button type="submit"
                                                class="px-3 py-1 bg-red-500 text-white rounded-lg hover:bg-red-600 transition text-xs">
                                            Delete
                                        </button>
                                    </form>

                                </div>
                            </td>

                        </tr>
                    }

                </tbody>

            </table>
        </div>
    </div>

</div>