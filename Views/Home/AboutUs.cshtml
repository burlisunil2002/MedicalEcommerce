<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>About Us - Medical Products</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="css/aboutus.css" rel="stylesheet">
</head>
<body>

    <!-- TOP HEADER BAR -->
    <div class="about-topbar">
        <div class="container">
            <div class="topbar-content">

                <!-- Page Title CENTER -->
                <h5 class="page-title">About Us</h5>

            </div>
        </div>
    </div>

    <!-- ABOUT SECTION -->
    <section class="about-section py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <img src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5"
                         class="img-fluid rounded shadow about-img"
                         alt="Medical Team">
                </div>
                <div class="col-md-6">
                    <h2 class="section-title">Who We Are</h2>
                    <p>
                        We are a trusted provider of certified medical products including surgical tools,
                        diagnostic equipment, hospital supplies, and healthcare essentials.
                    </p>
                    <p>
                        Our ERP-powered inventory management system ensures real-time stock updates,
                        fast delivery, and reliable supply chain management.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="features-section py-5">
        <div class="container text-center">
            <h2 class="section-title">Why Choose Us</h2>
            <div class="row g-4 mt-4">

                <div class="col-md-3">
                    <div class="feature-card">
                        <h5>Certified Quality</h5>
                        <p>All products comply with international safety standards.</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="feature-card">
                        <h5>Fast Delivery</h5>
                        <p>Efficient logistics with real-time tracking.</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="feature-card">
                        <h5>Affordable Pricing</h5>
                        <p>Competitive pricing for hospitals and clinics.</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="feature-card">
                        <h5>24/7 Support</h5>
                        <p>Dedicated professional support team.</p>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- STATS SECTION -->
    <section class="stats-section text-center">
        <div class="container">
            <div class="row">

                <div class="col-md-3">
                    <div class="stat-box">
                        <h2>10+</h2>
                        <p>Years Experience</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="stat-box">
                        <h2>500+</h2>
                        <p>Hospitals Served</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="stat-box">
                        <h2>2000+</h2>
                        <p>Products Available</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="stat-box">
                        <h2>100%</h2>
                        <p>Quality Assurance</p>
                    </div>
                </div>

            </div>
        </div>
